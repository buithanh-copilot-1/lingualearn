# Base path for deployment
# Root domain (Vercel, Netlify, custom domain): leave as / or unset
# GitHub Pages project site (username.github.io/repo-name/): /lingualearn/
# VITE_BASE_PATH=/

# Backend API URL (production / split deploy)
# Local dev: leave unset — Vite proxies /api to http://localhost:3001
# VITE_API_URL=https://your-api.railway.app
