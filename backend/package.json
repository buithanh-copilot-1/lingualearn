{
  "name": "lingualearn-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "railway:build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "start:prod": "node dist/index.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:prod:update": "tsx scripts/update-prod-db.ts",
    "db:prod:push": "tsx scripts/update-prod-db.ts --push-only",
    "db:prod:seed": "tsx scripts/update-prod-db.ts --seed-only",
    "sync:data": "node scripts/sync-seed-data.mjs",
    "build:vocab": "node scripts/build-vocabulary.mjs",
    "clean:vocab": "node scripts/clean-vocabulary.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/static": "^9.1.3",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "prisma": "^6.19.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "web-push": "^3.6.7",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.21",
    "@types/web-push": "^3.6.4"
  }
}
