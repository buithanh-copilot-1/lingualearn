# Production database — Railway PostgreSQL (PUBLIC URL for local scripts)
# Copy this file to .env.production and fill in values from Railway Dashboard.
# NEVER commit .env.production to git.

# Variables tab → Postgres service → DATABASE_PUBLIC_URL
DATABASE_PUBLIC_URL="postgresql://postgres:YOUR_PASSWORD@YOUR_HOST.proxy.rlwy.net:PORT/railway"

# Optional: internal URL (only works inside Railway network, not for local scripts)
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@postgres.railway.internal:5432/railway"
