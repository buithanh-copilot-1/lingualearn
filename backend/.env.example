# PostgreSQL — Railway injects DATABASE_URL automatically when you add a Postgres plugin
# Local dev (docker compose up -d):
DATABASE_URL="postgresql://lingualearn:lingualearn@localhost:5432/lingualearn?schema=public"

# Required in production (Railway Variables)
JWT_SECRET="change-me-to-a-long-random-secret-in-production"
JWT_REFRESH_SECRET="change-me-to-another-long-random-secret"

# Comma-separated allowed frontend origins (your Vercel URL)
CORS_ORIGIN="http://localhost:5173,https://your-app.vercel.app"

ACCESS_TOKEN_EXPIRES="15m"
REFRESH_TOKEN_EXPIRES_DAYS=7
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
